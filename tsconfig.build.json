{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"emitDeclarationOnly": true,
		"rootDir": "src",
		"outDir": "dist"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["src/test", "src/**/stories/**", "src/**/*.test.ts", "src/**/*.test.tsx", "src/styles-entry.ts"]
}
