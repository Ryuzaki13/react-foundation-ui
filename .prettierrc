{
	"singleQuote": false,
	"semi": true,
	"bracketSpacing": true,
	"bracketSameLine": true,
	"useTabs": true,
	"tabWidth": 4,
	"printWidth": 140,
	"trailingComma": "none",
	"arrowParens": "always",
	"overrides": [
		{
			"files": ["*.yml"],
			"options": {
				"tabWidth": 2,
				"useTabs": false
			}
		}
	]
}
