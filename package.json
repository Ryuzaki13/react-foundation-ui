	"scripts": {
		"build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
		"typecheck": "tsc -p tsconfig.build.json --noEmit",
		"test": "vitest run",
		"lint": "eslint --config eslint.config.ts .",
		"lint:fix": "eslint --config eslint.config.ts . --fix",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"validate": "npm run lint && npm run typecheck && npm run test && npm run build",
		"pack:dry-run": "npm run validate && npm run build-storybook && npm pack --dry-run",
		"build-package": "npm run build && npm run build-storybook",
		"serve-storybook": "npx http-server storybook-static"
	},
