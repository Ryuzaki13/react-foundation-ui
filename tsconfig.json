{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"jsx": "react-jsx",
		"types": [
			"vite/client"
		],
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"noEmit": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		".storybook/**/*.ts",
		"vite.config.ts"
	]
}
